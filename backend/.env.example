# Secure Backend Environment Configuration
# Duplicate this file, rename it to '.env', and fill in your values.
# NEVER commit your '.env' file with real credentials to GitHub!

# The port where your Express backend will run (Render handles this automatically)
PORT=3000

# Your secure MongoDB Atlas Connection URL
# Replace this with your actual database connection string!
MONGODB_URl="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ContactUs?retryWrites=true&w=majority"

# Your Google Gemini AI API Key (required for AI features)
GEMINI_API_KEY="your_google_gemini_api_key_here"
